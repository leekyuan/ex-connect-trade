# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# App mode
VITE_APP_ENV=development
VITE_TRADING_MODE=paper

# Server-side live trading guard.
# Keep LIVE_TRADING_ENABLED=false until review, testnet/paper verification,
# endpoint allowlisting, and emergency procedures are complete.
LIVE_TRADING_ENABLED=false
ALLOWED_TRADING_SYMBOLS=BTCUSDT,ETHUSDT,BTC/USDT:USDT,ETH/USDT:USDT
MAX_LIVE_LEVERAGE=5
MAX_POSITION_USDT=100
ACCOUNT_EQUITY_USDT=10000
MAX_PER_TRADE_LOSS_PCT=1
MAX_PER_TRADE_LOSS_USDT=100
MAX_DAILY_LOSS_USDT=300
ALLOW_UNPROTECTED_MARKET_ORDERS=false

# Local-only exchange API placeholders.
# Real exchange API keys must never be committed.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Supabase Edge Function secrets.
# Configure these in Supabase/Lovable secrets, not in GitHub.
SUPABASE_URL=
SUPABASE_ANON_KEY=
LOVABLE_API_KEY=
TELEGRAM_API_KEY=
CMC_API_KEY=
